---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vergleich"
  description="Vergleichen Sie die besten Unfallversicherungen für Kinder. Finden Sie den optimalen Tarif für Ihre Familie."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-8">Unfallversicherung Vergleich</h1>

    <div class="bg-primary-50 border border-primary-200 rounded-lg p-8 mb-8">
      <h2 class="text-2xl font-semibold mb-4">Finden Sie die beste Versicherung für Ihr Kind</h2>
      <p class="text-gray-700 mb-6">
        Vergleichen Sie Leistungen und Preise der führenden Anbieter und wählen Sie den optimalen Schutz für Ihre Familie.
      </p>
    </div>

    <div class="bg-white rounded-lg shadow-md border border-gray-200 p-8 mb-8">
      <h3 class="text-xl font-semibold mb-4">Wichtige Vergleichskriterien</h3>
      <ul class="space-y-3">
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <span>Versicherungssumme (mindestens 200.000 Euro empfohlen)</span>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <span>Progression (225%, 350% oder 500%)</span>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <span>Weltweiter Schutz rund um die Uhr</span>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <span>Keine Ausschlüsse für Kindersportarten</span>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <span>Zusatzleistungen wie Krankenhaustagegeld</span>
        </li>
      </ul>
    </div>

    <div class="bg-gray-50 rounded-lg p-8 text-center">
      <p class="text-gray-600 mb-4">Detaillierte Informationen finden Sie in unserem Ratgeber:</p>
      <a href="/artikel/unfallversicherung-kinder-vergleich-ratgeber" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-700 no-underline">
        Zum Ratgeber
      </a>
    </div>
  </div>
</BaseLayout>
